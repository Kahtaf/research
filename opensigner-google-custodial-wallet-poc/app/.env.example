APP_URL=http://localhost:3000
APP_SESSION_SECRET=replace-with-32-byte-random-secret

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloud SQL / MySQL. Prefer DATABASE_URL in local dev if available.
DATABASE_URL=
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USERNAME=
MYSQL_PASSWORD=
MYSQL_DATABASE=opensigner_poc
MYSQL_SOCKET_PATH=
DB_SSL_REJECT_UNAUTHORIZED=true

# JWT accepted by OpenSigner hot storage and Shield custom provider.
# Production should use RS256 keys so Shield can validate via /.well-known/jwks.json.
OPENSIGNER_JWT_PRIVATE_KEY=
OPENSIGNER_JWT_PUBLIC_KEY=
OPENSIGNER_JWT_PUBLIC_JWK=
OPENSIGNER_JWT_KEY_ID=opensigner-poc-key
OPENSIGNER_JWT_HS_SECRET=local-development-only

# Hot share encryption, exactly 64 hex chars. Generate with: openssl rand -hex 32
SHARE_ENCRYPTION_KEY=

# Server-side Shield configuration. Do not expose the secret or encryption part to the browser.
SHIELD_URL=http://localhost:7053
SHIELD_API_KEY=
SHIELD_API_SECRET=
OPENSIGNER_DEVELOPER_ENCRYPTION_PART=

# Browser-visible OpenSigner endpoints.
NEXT_PUBLIC_OPENSIGNER_IFRAME_URL=http://localhost:7050/index.html?debug=true
NEXT_PUBLIC_HOT_STORAGE_URL=http://localhost:3000
NEXT_PUBLIC_SHIELD_URL=http://localhost:7053
NEXT_PUBLIC_SHIELD_API_KEY=
NEXT_PUBLIC_CHAIN_ID=1

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:7050
