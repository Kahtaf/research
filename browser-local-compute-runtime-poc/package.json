{
  "name": "browser-local-compute-runtime-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build:tls-wasm": "wasm-pack build browser-tls-rustls --target web --out-dir pkg --release",
    "build": "npm run build:tls-wasm && tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "reverse-relay:build": "npm --prefix reverse-blind-relay run build",
    "reverse-relay:dev": "npm --prefix reverse-blind-relay run dev",
    "reverse-relay:smoke": "npm --prefix reverse-blind-relay run build && npm --prefix reverse-blind-relay run smoke",
    "reverse-relay:deploy:gcp-vm": "bash reverse-blind-relay/scripts/deploy-gcp-vm.sh",
    "deploy": "npm run build && wrangler deploy",
    "deploy:cf": "npm run deploy"
  },
  "dependencies": {
    "nanoid": "^5.1.6",
    "node-forge": "^1.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/node-forge": "^1.3.14",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "wrangler": "^4.49.0"
  }
}
