    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "wrangler": "^4.49.0"
  }
